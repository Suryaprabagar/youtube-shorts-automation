# ============================================================
# YouTube Shorts Automation - Environment Variables Template
# ============================================================
# Copy this file to .env for local development.
# For GitHub Actions, add these as repository Secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# ── OpenRouter (LLM for script + metadata generation) ────────
# Sign up free at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Pexels (free stock video downloads) ──────────────────────
# Get free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ── YouTube Data API v3 (OAuth 2.0) ──────────────────────────
# See README.md → "YouTube OAuth Setup" for step-by-step instructions.
YOUTUBE_CLIENT_ID=your_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_oauth_refresh_token_here

# ── Optional overrides ────────────────────────────────────────
TTS_LANGUAGE=en
TTS_SLOW=false
YT_CATEGORY_ID=22
YT_PRIVACY=public
